# Backend database connection
# Copy to .env and replace placeholders with your actual database values.
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# LLM configuration (optional - defaults to mock mode)
# LLM_PROVIDER=openai          # gemini | openai | ollama | groq
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=5oikR8cs...
# OPENAI_BASE_URL=https://openaiqc.gep.com/summerintern/openai/v1
# OPENAI_MODEL=gpt-4o-mini
# LLM_MOCK=false
# SUMMARY_WINDOW_TOKENS=1500
# KNOWLEDGE_DATA_DIR=data/knowledge


# Groq Configuration
